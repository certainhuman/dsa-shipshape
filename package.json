{
  "name": "dsa-shipshape",
  "version": "1.0.0",
  "description": "TypeScript utilities for parsing, editing, and encoding Deep Space Airships blueprints for drednot.io.",
  "license": "MIT",
  "homepage": "https://github.com/certainhuman/dsa-shipshape#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/certainhuman/dsa-shipshape.git"
  },
  "bugs": {
    "url": "https://github.com/certainhuman/dsa-shipshape/issues"
  },
  "keywords": [
    "deep-space-airships",
    "drednot",
    "drednot.io",
    "blueprint",
    "dsa",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.js",
  "unpkg": "./dist/browser/dsa-shipshape.global.js",
  "jsdelivr": "./dist/browser/dsa-shipshape.global.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "docs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "check": "npm run typecheck && npm test",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run check && npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
